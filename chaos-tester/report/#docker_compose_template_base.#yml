# docker-compose.yml
version: '3.8'

services:
  # Reverse Proxy (per gestire più domini/porte)
  traefik:
    image: traefik:v2.5
    command:
      - --api.insecure=true
      - --providers.docker
    ports:
      - "80:80"
      - "8080:8080"  # Dashboard di Traefik
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock

  # Database (MySQL/PostgreSQL)
  db:
    image: postgres:13
    environment:
      POSTGRES_USER: dev
      POSTGRES_PASSWORD: dev
      POSTGRES_DB: test
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - backend

  # Cache (Redis)
  redis:
    image: redis:6
    volumes:
      - redisdata:/data
    networks:
      - backend

  # Monitoring (Prometheus + Grafana)
  prometheus:
    image: prom/prometheus:latest
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml
    ports:
      - "9090:9090"
    networks:
      - backend

  grafana:
    image: grafana/grafana:latest
    depends_on:
      - prometheus
    ports:
      - "3000:3000"
    networks:
      - backend

  # Utility per test (es. curl, ping)
  utils:
    image: alpine:latest
    command: tail -f /dev/null  # Container rimane attivo
    networks:
      - backend

volumes:
  pgdata:
  redisdata:

networks:
  backend: